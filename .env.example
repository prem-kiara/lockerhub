# LockerHub Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8080
NODE_ENV=development

# JWT Authentication
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated allowed origins, or * for dev only)
CORS_ORIGINS=http://localhost:8080

# Digio E-Sign
DIGIO_ENV=sandbox
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=

# Microsoft Graph / SharePoint
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
SP_DRIVE_ID=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
